#!/usr/bin/env bash
#===============================================================================
# git-credential-keyring — Kapsis git credential helper
#
# Bridges git's credential protocol to the container's gnome-keyring.
# Looks up credentials from a map file that associates git hosts with
# keyring entries populated by inject_secret_store() at container startup.
#
# Supports two keyring lookup paths:
#   1. 99designs/keyring compat: secret-tool lookup profile "$key"
#   2. Standard secret-tool:     secret-tool lookup service "$svc" account "$acct"
#
# Only implements 'get'. 'store' and 'erase' are no-ops — the keyring is
# managed by the entrypoint, not by git.
#
# Map file format (pipe-delimited, one entry per line):
#   host|service|account|keyring_collection|keyring_profile
#
# See: https://github.com/aviadshiber/kapsis/issues/188
#===============================================================================
set -euo pipefail

CREDENTIAL_MAP="${KAPSIS_GIT_CREDENTIAL_MAP:-/opt/kapsis/git-credential-map}"

# Only handle 'get' operation — store/erase are no-ops
action="${1:-}"
if [[ "$action" != "get" ]]; then
    exit 0
fi

# Parse git credential protocol from stdin
protocol=""
host=""
username=""
while IFS='=' read -r key value; do
    [[ -z "$key" ]] && break
    case "$key" in
        protocol) protocol="$value" ;;
        host)     host="$value" ;;
        username) username="$value" ;;
    esac
done

# Must have host to look up
[[ -z "$host" ]] && exit 0

# Strip port from host if present (git sends host:port)
local_host="${host%%:*}"

# Map file must exist
[[ ! -f "$CREDENTIAL_MAP" ]] && exit 0

# Look up host in credential map
matched_service=""
matched_account=""
matched_collection=""
matched_profile=""

while IFS='|' read -r map_host map_service map_account map_collection map_profile; do
    # Skip comments and empty lines
    [[ "${map_host:-}" == "#"* ]] && continue
    [[ -z "${map_host:-}" ]] && continue

    if [[ "$local_host" == "$map_host" ]]; then
        matched_service="$map_service"
        matched_account="${map_account:-}"
        matched_collection="${map_collection:-}"
        matched_profile="${map_profile:-}"
        break
    fi
done < "$CREDENTIAL_MAP"

# No match found — let git try next helper
[[ -z "$matched_service" ]] && exit 0

# secret-tool required for keyring lookup
if ! command -v secret-tool &>/dev/null; then
    exit 0
fi

password=""

# Path 1: 99designs/keyring compat (lookup by 'profile' attribute)
if [[ -n "$matched_collection" ]]; then
    lookup_key="${matched_profile:-${matched_account}}"
    if [[ -n "$lookup_key" ]]; then
        password=$(secret-tool lookup profile "$lookup_key" 2>/dev/null) || true
    fi
fi

# Path 2: Standard secret-tool fallback (lookup by service + account)
if [[ -z "$password" ]] && [[ -n "$matched_service" ]]; then
    password=$(secret-tool lookup service "$matched_service" account "${matched_account:-kapsis}" 2>/dev/null) || true
fi

# No password found — silent exit
[[ -z "$password" ]] && exit 0

# Output in git credential format
echo "protocol=${protocol:-https}"
echo "host=$host"
echo "username=${username:-${matched_account}}"
echo "password=$password"
